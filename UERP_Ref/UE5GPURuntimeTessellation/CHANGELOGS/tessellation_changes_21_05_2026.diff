+		return SampleOceanFFTDisplacement(LocalXY).z;
+	}
+	if (OceanWaveMode == 3u)
+	{
+		return OceanPerlinFBM(RemappedUV);
+	}
+	return 0.0;
+}
+
+float3 EvaluateOceanOffset(float2 RemappedUV)
+{
+	if (OceanWaveMode == 2u)
+	{
