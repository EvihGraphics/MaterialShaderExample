+		BuildNode(FVector2f(PatchOffset.X, PatchOffset.Y + ChildSize.Y), ChildSize, Depth + 1);
+		BuildNode(FVector2f(PatchOffset.X + ChildSize.X, PatchOffset.Y + ChildSize.Y), ChildSize, Depth + 1);
