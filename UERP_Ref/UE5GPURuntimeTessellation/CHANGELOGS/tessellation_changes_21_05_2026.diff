+float4 SampleOceanFFTDisplacement(float2 LocalXY)
+{
+	float TileSize = max(OceanFFTTileSize, 1.0);
+	float2 SampleXY = LocalXY;
+	float AmplitudeScale = 1.0;
+
+	if (OceanFFTMotionMode == 1u)
+	{
+		float SwayStrength = clamp(OceanFFTSwayIntensity, 0.0, 2.0);
+		if (SwayStrength > 1e-4)
+		{
+			float2 Wind = OceanSafeNormalize2(OceanFFTWindDir, float2(1.0, 0.0));
+			float2 CrossWind = float2(-Wind.y, Wind.x);
+			float Phase = OceanTime * max(OceanFFTSwayRate, 0.001) * 6.2831853;
+			float FlowDistance = max(OceanFFTWindSpeed, 1.0) * max(OceanFFTSwayDrift, 0.0) * OceanTime;
+
+			// Low-frequency wave groups. The effect is intentionally larger than FFT texels but
+			// smaller than the whole tile, so rough-sea motion happens in local patches instead
+			// of translating the entire displacement map as one sheet.
+			float GroupScaleA = max(TileSize * 0.18, 1500.0);
+			float GroupScaleB = max(TileSize * 0.071, 900.0);
+			float3 GroupPA = float3((LocalXY - Wind * FlowDistance) / GroupScaleA, OceanTime * max(OceanFFTSwayRate, 0.001) * 0.37);
+			float3 GroupPB = float3((LocalXY + CrossWind * FlowDistance * 0.43 + float2(371.0, 193.0)) / GroupScaleB, OceanTime * max(OceanFFTSwayRate, 0.001) * 0.61 + 11.7);
+			float GroupA = OceanPerlinNoise3D(GroupPA);
+			float GroupB = OceanPerlinNoise3D(GroupPB);
+
+			float LocalPhase = Phase + GroupA * 2.4 + GroupB * 1.1;
+			float Surge = sin(LocalPhase) + 0.38 * sin(LocalPhase * 2.13 + GroupB * 3.0 + 1.2);
+			float LocalSet = saturate(0.5 + 0.5 * (0.72 * GroupA + 0.28 * GroupB));
+
+			float ForwardWarp = TileSize * 0.010 * SwayStrength * Surge * (0.35 + 0.65 * LocalSet);
+			float CrossWarp = TileSize * 0.0035 * SwayStrength * GroupB;
+			SampleXY += Wind * ForwardWarp + CrossWind * CrossWarp;
+
+			AmplitudeScale = max(0.65, 1.0 + SwayStrength * 0.16 * (LocalSet - 0.5) + SwayStrength * 0.045 * Surge);
+		}
+	}
+
+	float2 TiledUV = frac(SampleXY / TileSize);
+	float4 FFT = OceanFFTDisplacementMap.SampleLevel(OceanFFTDisplacementMapSampler, TiledUV, 0);
+	FFT.xyz *= AmplitudeScale;
+	return FFT;
+}
