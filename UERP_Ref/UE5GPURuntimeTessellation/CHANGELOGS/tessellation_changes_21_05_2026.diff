+		Leaf.ResolutionY = LeafResolution.Y;
+		Leaf.QuadtreeNodeIndex = static_cast<int32>(HashCombine(
+			GetTypeHash(FMath::RoundToInt(PatchOffset.X * 65535.0f)),
