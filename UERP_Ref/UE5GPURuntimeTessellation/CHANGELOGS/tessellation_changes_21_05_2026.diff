+float3 EvaluateVectorDisplacementOffset(float2 RemappedUV, float3 BaseNormal)
+{
+	float4 Sample = SampleVectorDisplacementTextureLinear(VectorDisplacementTexture, RemappedUV);
+	float3 Offset = DecodeVectorDisplacementSample(Sample);
+
+	if (VectorDisplacementSpace == 1u)
+	{
+		return mul(float4(Offset, 0.0), WorldToLocal).xyz;
+	}
+
+	if (VectorDisplacementSpace == 2u)
+	{
+		float3 TangentX = float3(1.0, 0.0, 0.0);
+		float3 TangentY = float3(0.0, 1.0, 0.0);
+		return TangentX * Offset.x + TangentY * Offset.y + BaseNormal * Offset.z;
+	}
+
+	return Offset;
+}
