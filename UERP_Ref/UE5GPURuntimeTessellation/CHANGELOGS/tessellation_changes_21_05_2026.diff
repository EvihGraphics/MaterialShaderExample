+
+float3 DecodeVectorDisplacementSample(float4 Sample)
+{
+	float3 Decoded = Sample.rgb;
+
+	// 1 = 0..1 encoded where 0.5 means no displacement.
+	if (VectorDisplacementDecodeMode == 1u)
+	{
+		Decoded = Decoded * 2.0 - 1.0;
+	}
+
+	float Strength = bUseVectorDisplacementAlphaAsStrength != 0u ? Sample.a : 1.0;
+	return (Decoded * VectorDisplacementScale + VectorDisplacementBias) * VectorDisplacementIntensity * Strength;
+}
