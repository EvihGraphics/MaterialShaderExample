+			(RemappedUV.x - 0.5) * OceanPlaneSizeX,
+			(RemappedUV.y - 0.5) * OceanPlaneSizeY);
+		return SampleOceanFFTDisplacement(LocalXY).xyz;
+	}
+
+	return float3(0.0, 0.0, EvaluateOceanHeight(RemappedUV));
+}
