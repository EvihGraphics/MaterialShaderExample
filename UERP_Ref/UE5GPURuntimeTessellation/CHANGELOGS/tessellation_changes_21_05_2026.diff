+	uint32 GPUTessellationGradHash(uint32 GridX, uint32 GridY, uint32 GridZ, uint32 Salt)
+	{
+		uint32 Hash = GridX * 374761393u + GridY * 668265263u + GridZ * 1274126177u + Salt * 2147483647u;
+		Hash = (Hash ^ (Hash >> 13u)) * 1274126177u;
+		Hash ^= Hash >> 16u;
+		return Hash;
+	}
