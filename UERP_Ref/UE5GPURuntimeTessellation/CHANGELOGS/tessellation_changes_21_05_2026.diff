+	auto ReindexLeaves = [&]()
+	{
+		for (int32 LeafIndex = 0; LeafIndex < OutPatchInfo.Num(); ++LeafIndex)
+		{
+			OutPatchInfo[LeafIndex].PatchIndexX = LeafIndex;
+			OutPatchInfo[LeafIndex].PatchIndexY = OutPatchInfo[LeafIndex].QuadtreeDepth;
+		}
+	};
