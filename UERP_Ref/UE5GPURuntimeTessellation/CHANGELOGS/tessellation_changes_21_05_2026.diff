+	auto IntervalOverlap = [](float A0, float A1, float B0, float B1) -> float
+	{
+		return FMath::Max(0.0f, FMath::Min(A1, B1) - FMath::Max(A0, B0));
+	};
+
+	auto IsNearlyTouching = [Epsilon](float A, float B) -> bool
+	{
+		return FMath::Abs(A - B) <= Epsilon;
+	};
