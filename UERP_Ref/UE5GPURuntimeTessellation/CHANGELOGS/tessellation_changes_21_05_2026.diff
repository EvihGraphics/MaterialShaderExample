+void UGPUTessellationComponent::MarkCollisionMeshDirty()
+{
+	bCollisionMeshDirty = true;
+	bCollisionLODRingSourceDirty = true;
+	LastVertexPerfectCollisionVisualLODSignature = 0;
+}
